{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "home-azure": {
        "ClusterId": "azure",
        "Match": {
          "Path": "{**catch-all}",
          "Headers": [
            {
              "Name": "X-Force-Routing",
              "Values": [ "azure" ],
              "Mode": "Contains",
              "IsCaseSensitive": false
            }
          ]
        }
      },
      "home-onpremise": {
        "ClusterId": "onpremise",
        "Match": {
          "Path": "{**catch-all}",
          "Headers": [
            {
              "Name": "X-Force-Routing",
              "Values": [ "azure" ],
              "Mode": "NotContains",
              "IsCaseSensitive": false
            }
          ]
        }
      }
    },
    "Clusters": {
      "azure": {
        "Destinations": {
          "destination": {
            "Address": "https://webapi-azure/"
          }
        }
      },
      "onpremise": {
        "Destinations": {
          "destination": {
            "Address": "https://webapi-onpremise/"
          }
        }
      }
    }
  }
}
